# Copy to .env.local and fill in. Maps embed needs a browser-exposed key (restrict by HTTP referrer in Google Cloud).
# Enable for the same project key: Maps JavaScript API (kort), Geocoding, Directions API (transit), Weather API (forecast).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Server-side only — use when you add Gemini / Generative Language API calls (never NEXT_PUBLIC_).
GOOGLE_AI_API_KEY=
